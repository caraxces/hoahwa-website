# Site
NEXT_PUBLIC_SITE_URL=https://hoahwa.com

# Contact form API (static export uses PHP on Hostinger)
# Production: same-origin /api/contact.php
# Local dev: point to production API (PHP does not run in `next dev`)
NEXT_PUBLIC_CONTACT_API_URL=https://hoahwa.com/api/contact.php

# Hostinger MySQL — used by scripts/generate-contact-api-config.mjs (never commit values)
HOSTINGER_DB_HOST=localhost
HOSTINGER_DB_NAME=u525593444_hoahwa
HOSTINGER_DB_USER=u525593444_hoa
HOSTINGER_DB_PASS=

# Portfolio builder APIs (static export uses PHP on Hostinger)
# Local dev: point to production API (PHP does not run in `next dev`)
NEXT_PUBLIC_PORTFOLIO_AUTH_API_URL=https://hoahwa.com/api/portfolio-auth.php
NEXT_PUBLIC_PORTFOLIO_PAGES_API_URL=https://hoahwa.com/api/portfolio-pages.php
NEXT_PUBLIC_PORTFOLIO_SEED_API_URL=https://hoahwa.com/api/portfolio-seed.php

# Hostinger deploy API
HOSTINGER_API_TOKEN=
